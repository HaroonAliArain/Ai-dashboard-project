{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private information for users.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "ChatThread": {
      "title": "Chat Thread",
      "description": "A conversation thread between a user and the AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual message within a chat thread.",
      "type": "object",
      "properties": {
        "threadId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/threads/{threadId}": {
      "schema": "ChatThread",
      "description": "Chat threads for a specific user."
    },
    "/users/{userId}/threads/{threadId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat thread."
    }
  }
}
